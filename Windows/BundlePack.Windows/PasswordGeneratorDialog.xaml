<ContentDialog
    x:Class="BundlePack.Windows.PasswordGeneratorDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Password Generator"
    PrimaryButtonText="Use Password"
    CloseButtonText="Cancel"
    DefaultButton="Primary">

    <StackPanel Width="480" Spacing="16">
        <TextBlock Text="Choose the exact total length and character counts." Opacity="0.65" />

        <StackPanel Spacing="6">
            <Grid>
                <TextBlock Text="Generated Password" FontWeight="SemiBold" />
                <TextBlock x:Name="CharacterCountText" HorizontalAlignment="Right" Opacity="0.6" />
            </Grid>
            <TextBox x:Name="GeneratedPasswordTextBox" IsReadOnly="True" IsHitTestVisible="False" IsTabStop="False" FontFamily="Consolas" />
            <TextBlock Text="The password is shown in plain text for review. Use Copy for a non-roaming clipboard item that is cleared after 60 seconds." FontSize="12" TextWrapping="Wrap" Opacity="0.6" />
        </StackPanel>

        <Grid ColumnSpacing="16" RowSpacing="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="150" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Total Length" VerticalAlignment="Center" />
            <NumberBox x:Name="TotalLengthNumberBox" Grid.Row="0" Grid.Column="1" Minimum="12" Maximum="128" Value="16" SpinButtonPlacementMode="Compact" ValueChanged="Settings_ValueChanged" />
            <TextBlock Grid.Row="1" Text="Digits" VerticalAlignment="Center" />
            <NumberBox x:Name="DigitsNumberBox" Grid.Row="1" Grid.Column="1" Minimum="0" Maximum="64" Value="4" SpinButtonPlacementMode="Compact" ValueChanged="Settings_ValueChanged" />
            <TextBlock Grid.Row="2" Text="Symbols" VerticalAlignment="Center" />
            <NumberBox x:Name="SymbolsNumberBox" Grid.Row="2" Grid.Column="1" Minimum="0" Maximum="64" Value="4" SpinButtonPlacementMode="Compact" ValueChanged="Settings_ValueChanged" />
            <StackPanel Grid.Row="3">
                <TextBlock Text="Letters" />
                <TextBlock Text="Includes at least one uppercase and one lowercase letter" FontSize="12" Opacity="0.6" />
            </StackPanel>
            <TextBlock x:Name="LettersCountText" Grid.Row="3" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" />
        </Grid>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
            <Button Click="Copy_Click">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <SymbolIcon Symbol="Copy" />
                    <TextBlock Text="Copy" />
                </StackPanel>
            </Button>
            <Button Content="Generate" Click="Generate_Click" />
        </StackPanel>
    </StackPanel>
</ContentDialog>
