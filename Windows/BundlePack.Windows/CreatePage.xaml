<UserControl
    x:Class="BundlePack.Windows.CreatePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:BundlePack.Windows">

    <Grid x:Name="RootGrid">
        <ScrollViewer
            x:Name="PageScrollViewer"
            HorizontalContentAlignment="Stretch"
            HorizontalScrollBarVisibility="Disabled"
            HorizontalScrollMode="Disabled"
            VerticalScrollBarVisibility="Auto"
            VerticalScrollMode="Enabled"
            ZoomMode="Disabled">
            <StackPanel
                x:Name="RootContent"
                MaxWidth="1040"
                Margin="32,24,32,40"
                HorizontalAlignment="Center"
                Spacing="28">
                <StackPanel Spacing="4">
                    <TextBlock Text="Package Information" Style="{ThemeResource TitleTextBlockStyle}" />
                    <TextBlock Text="Basic information shown after the package is unlocked." Opacity="0.65" />
                </StackPanel>

                <Grid ColumnSpacing="28">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="210" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" HorizontalAlignment="Center" Spacing="8">
                        <Border
                            x:Name="IconDropZone"
                            Width="168"
                            Height="168"
                            Padding="8"
                            AllowDrop="True"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="22"
                            DragEnter="Icon_DragEnter"
                            DragLeave="Icon_DragLeave"
                            DragOver="Icon_DragOver"
                            Drop="Icon_Drop"
                            AutomationProperties.Name="Package icon drop area">
                            <Grid>
                                <Image x:Name="IconPreview" Stretch="Uniform" />
                                <Button
                                    x:Name="RemoveIconButton"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    Click="RemoveIcon_Click"
                                    ToolTipService.ToolTip="Use the default icon"
                                    Visibility="Collapsed">
                                    <SymbolIcon Symbol="Cancel" />
                                </Button>
                                <Border
                                    x:Name="IconDropHighlight"
                                    Margin="-8"
                                    BorderBrush="{ThemeResource AccentFillColorDefaultBrush}"
                                    BorderThickness="3"
                                    CornerRadius="22"
                                    IsHitTestVisible="False"
                                    Visibility="Collapsed" />
                            </Grid>
                        </Border>
                        <Button Content="Choose Icon…" Click="ChooseIcon_Click" HorizontalAlignment="Center" />
                        <TextBlock Text="or drop an image" FontSize="12" Opacity="0.55" />
                    </StackPanel>

                    <Grid Grid.Column="1" RowSpacing="12" ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Name" VerticalAlignment="Center" HorizontalAlignment="Right" />
                        <TextBox x:Name="NameTextBox" Grid.Row="0" Grid.Column="1" PlaceholderText="Example: Project Assets" />
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Version" VerticalAlignment="Center" HorizontalAlignment="Right" />
                        <TextBox x:Name="VersionTextBox" Grid.Row="1" Grid.Column="1" Text="1.0.0" />
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Author" VerticalAlignment="Center" HorizontalAlignment="Right" />
                        <TextBox x:Name="AuthorTextBox" Grid.Row="2" Grid.Column="1" PlaceholderText="Optional" />
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Description" VerticalAlignment="Center" HorizontalAlignment="Right" />
                        <TextBox x:Name="DescriptionTextBox" Grid.Row="3" Grid.Column="1" PlaceholderText="Briefly describe the package" />
                    </Grid>
                </Grid>

                <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />

                <StackPanel Spacing="14">
                    <Grid ColumnSpacing="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock Text="Included Files" Style="{ThemeResource TitleTextBlockStyle}" />
                            <TextBlock
                                Text="Add files and folders to the same package, or drop them in the area below."
                                Opacity="0.65"
                                TextWrapping="Wrap" />
                        </StackPanel>
                        <StackPanel
                            Grid.Column="1"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Orientation="Horizontal"
                            Spacing="8">
                            <Button Content="Add Files…" Click="AddFiles_Click" />
                            <Button Content="Add Folder…" Click="AddFolder_Click" />
                        </StackPanel>
                    </Grid>

                    <Border
                        x:Name="IncludedFilesDropZone"
                        MinHeight="150"
                        AllowDrop="True"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="12"
                        DragEnter="IncludedFiles_DragEnter"
                        DragLeave="IncludedFiles_DragLeave"
                        DragOver="IncludedFiles_DragOver"
                        Drop="IncludedFiles_Drop"
                        AutomationProperties.Name="Included files and folders drop area">
                        <Grid>
                            <StackPanel x:Name="EmptyFilesPanel" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
                                <FontIcon Glyph="&#xE896;" FontSize="36" Opacity="0.55" />
                                <TextBlock Text="No files added yet" FontWeight="SemiBold" HorizontalAlignment="Center" />
                                <TextBlock Text="Drag files or folders here" Opacity="0.6" HorizontalAlignment="Center" />
                            </StackPanel>
                            <ListView
                                x:Name="InputList"
                                ItemsSource="{x:Bind InputItems}"
                                ScrollViewer.HorizontalScrollMode="Disabled"
                                ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                ScrollViewer.VerticalScrollMode="Disabled"
                                ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                Visibility="Collapsed">
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="local:PackageInputItem">
                                        <Grid Padding="6" ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="{x:Bind Name}" FontWeight="SemiBold" />
                                                <TextBlock Text="{x:Bind Path}" FontSize="12" Opacity="0.55" TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                            <Button Grid.Column="1" Tag="{x:Bind Path}" Click="RemoveInput_Click" ToolTipService.ToolTip="Remove">
                                                <SymbolIcon Symbol="Cancel" />
                                            </Button>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                            <Border
                                x:Name="IncludedFilesDropHighlight"
                                BorderBrush="{ThemeResource AccentFillColorDefaultBrush}"
                                BorderThickness="3"
                                CornerRadius="12"
                                IsHitTestVisible="False"
                                Visibility="Collapsed" />
                        </Grid>
                    </Border>
                </StackPanel>

                <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />

                <StackPanel Spacing="14">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Protection" Style="{ThemeResource TitleTextBlockStyle}" />
                        <TextBlock Text="Choose encrypted protection or ZIP compatibility." Opacity="0.65" />
                    </StackPanel>

                    <Border
                        Padding="16"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="12">
                        <StackPanel Spacing="14">
                            <StackPanel Orientation="Horizontal" Spacing="24">
                                <RadioButton
                                    x:Name="EncryptedRadio"
                                    Content="Encrypted"
                                    GroupName="Protection"
                                    IsChecked="True"
                                    Checked="Protection_Checked" />
                                <RadioButton
                                    x:Name="UnencryptedRadio"
                                    Content="Unencrypted (ZIP Compatible)"
                                    GroupName="Protection"
                                    Checked="Protection_Checked" />
                            </StackPanel>

                            <Grid x:Name="PasswordPanel" ColumnSpacing="12" RowSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Password" HorizontalAlignment="Right" VerticalAlignment="Center" />
                                <PasswordBox x:Name="PasswordBox" Grid.Row="0" Grid.Column="1" PasswordRevealMode="Peek" PlaceholderText="At least 12 characters" />
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Confirm" HorizontalAlignment="Right" VerticalAlignment="Center" />
                                <PasswordBox x:Name="ConfirmPasswordBox" Grid.Row="1" Grid.Column="1" PasswordRevealMode="Peek" PlaceholderText="Enter the same password again" />
                                <Button Grid.Row="2" Grid.Column="1" Content="Generate Password…" HorizontalAlignment="Right" Click="GeneratePassword_Click" />
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <Grid ColumnSpacing="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        x:Name="PasswordReminderText"
                        Grid.Column="0"
                        Text="Share the password separately from the package. BundlePack does not save it."
                        Opacity="0.6"
                        VerticalAlignment="Center"
                        TextWrapping="Wrap" />
                    <Button
                        x:Name="CreateButton"
                        Grid.Column="1"
                        Content="Create BundlePack…"
                        HorizontalAlignment="Right"
                        Style="{StaticResource AccentButtonStyle}"
                        Click="Create_Click" />
                </Grid>

                <InfoBar x:Name="StatusInfoBar" IsOpen="False" IsClosable="True" />
            </StackPanel>
        </ScrollViewer>

        <Grid x:Name="BusyOverlay" Background="#66000000" Visibility="Collapsed">
            <Border
                Width="420"
                Padding="24"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                CornerRadius="12">
                <StackPanel Spacing="14">
                    <TextBlock x:Name="BusyMessageText" Text="Preparing files…" FontSize="18" FontWeight="SemiBold" TextWrapping="Wrap" />
                    <ProgressBar x:Name="BusyProgressBar" Minimum="0" Maximum="100" Value="0" />
                    <Grid>
                        <TextBlock x:Name="BusyPercentText" Text="0%" VerticalAlignment="Center" Opacity="0.65" />
                        <Button x:Name="CancelOperationButton" Content="Cancel" HorizontalAlignment="Right" Click="CancelOperation_Click" />
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
