<UserControl
    x:Class="BundlePack.Windows.OpenPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:BundlePack.Windows">

    <Grid x:Name="RootGrid" AllowDrop="True" DragOver="RootGrid_DragOver" Drop="RootGrid_Drop">
        <ScrollViewer
            x:Name="PageScrollViewer"
            HorizontalContentAlignment="Stretch"
            VerticalContentAlignment="Stretch"
            HorizontalScrollBarVisibility="Disabled"
            HorizontalScrollMode="Disabled"
            VerticalScrollBarVisibility="Auto"
            VerticalScrollMode="Enabled"
            ZoomMode="Disabled">
            <Grid x:Name="RootContent" MaxWidth="1040" Margin="32,24,32,40" HorizontalAlignment="Center">
                <StackPanel x:Name="InitialPanel" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
                    <Image Source="ms-appx:///Assets/DefaultPackageIcon.png" Width="150" Height="150" />
                    <TextBlock Text="Open a BundlePack" FontSize="30" FontWeight="SemiBold" HorizontalAlignment="Center" />
                    <TextBlock Text="Validate a .bundlepack file, review its contents, and extract it safely." Opacity="0.65" HorizontalAlignment="Center" />
                    <TextBlock Text="You can also drag a .bundlepack file into this window." Opacity="0.45" HorizontalAlignment="Center" />
                    <Button Content="Choose Package…" Style="{StaticResource AccentButtonStyle}" Click="ChoosePackage_Click" HorizontalAlignment="Center" Margin="0,8,0,0" />
                </StackPanel>

                <StackPanel x:Name="PackageContent" Spacing="24" Visibility="Collapsed">
                    <Grid ColumnSpacing="24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="190" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border
                            Width="170"
                            Height="170"
                            Padding="8"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="22">
                            <Image x:Name="PackageIcon" Stretch="Uniform" />
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="9">
                            <TextBlock x:Name="PackageTitleText" FontSize="34" FontWeight="SemiBold" TextWrapping="Wrap" />
                            <StackPanel x:Name="MetadataBadges" Orientation="Horizontal" Spacing="14" Visibility="Collapsed">
                                <TextBlock x:Name="VersionText" FontWeight="SemiBold" />
                                <TextBlock x:Name="FileCountText" FontWeight="SemiBold" />
                                <TextBlock x:Name="SizeText" FontWeight="SemiBold" />
                            </StackPanel>
                            <TextBlock x:Name="AuthorText" Opacity="0.65" Visibility="Collapsed" />
                            <TextBlock x:Name="SummaryText" Opacity="0.65" TextWrapping="Wrap" Visibility="Collapsed" />
                            <TextBlock x:Name="LockedDescriptionText" Text="File names and contents remain hidden until the package is unlocked." Opacity="0.65" Visibility="Collapsed" />
                        </StackPanel>
                    </Grid>

                    <Border
                        x:Name="UnlockPanel"
                        Padding="20"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Visibility="Collapsed">
                        <StackPanel Spacing="14">
                            <TextBlock Text="Encrypted BundlePack" FontSize="22" FontWeight="SemiBold" />
                            <Grid ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <PasswordBox x:Name="UnlockPasswordBox" PasswordRevealMode="Peek" PlaceholderText="Password" KeyDown="UnlockPassword_KeyDown" />
                                <Button Grid.Column="1" Content="Unlock" Style="{StaticResource AccentButtonStyle}" Click="Unlock_Click" />
                            </Grid>
                            <StackPanel Orientation="Horizontal" Spacing="22">
                                <TextBlock Text="AES-256-GCM" Opacity="0.6" />
                                <TextBlock Text="PBKDF2-SHA256" Opacity="0.6" />
                                <TextBlock Text="File List Hidden" Opacity="0.6" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <StackPanel x:Name="DetailsPanel" Spacing="12" Visibility="Collapsed">
                        <Grid>
                            <TextBlock Text="Contents" Style="{ThemeResource TitleTextBlockStyle}" />
                            <TextBlock x:Name="ExpandedSizeText" HorizontalAlignment="Right" Opacity="0.6" />
                        </Grid>
                        <Border
                            MinHeight="260"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="12">
                            <ListView
                                ItemsSource="{x:Bind Contents}"
                                ScrollViewer.HorizontalScrollMode="Disabled"
                                ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                ScrollViewer.VerticalScrollMode="Disabled"
                                ScrollViewer.VerticalScrollBarVisibility="Disabled">
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="local:PackageFileDisplay">
                                        <Grid Padding="8" ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{x:Bind Path}" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.Column="1" Text="{x:Bind DisplaySize}" Opacity="0.55" />
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Border>
                    </StackPanel>

                    <Grid>
                        <Button Content="Open Another Package…" Click="ChoosePackage_Click" />
                        <Button x:Name="ExtractButton" Content="Extract Safely…" HorizontalAlignment="Right" Style="{StaticResource AccentButtonStyle}" Click="Extract_Click" Visibility="Collapsed" />
                    </Grid>

                    <InfoBar x:Name="StatusInfoBar" IsOpen="False" IsClosable="True" />
                </StackPanel>
            </Grid>
        </ScrollViewer>

        <Grid x:Name="BusyOverlay" Background="#66000000" Visibility="Collapsed">
            <Border
                Width="420"
                Padding="24"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                CornerRadius="12">
                <StackPanel Spacing="14">
                    <TextBlock x:Name="BusyMessageText" Text="Reading package…" FontSize="18" FontWeight="SemiBold" TextWrapping="Wrap" />
                    <ProgressBar x:Name="BusyProgressBar" Minimum="0" Maximum="100" Value="0" />
                    <Grid>
                        <TextBlock x:Name="BusyPercentText" Text="0%" VerticalAlignment="Center" Opacity="0.65" />
                        <Button x:Name="CancelOperationButton" Content="Cancel" HorizontalAlignment="Right" Click="CancelOperation_Click" />
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
